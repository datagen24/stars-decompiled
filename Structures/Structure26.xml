<!--
  NOTE (cross-validated against decrypted real saves, 326 full designs + 16 unknown stubs):
    - `TotalBuilt` and `TotalRemaining` are **32-bit little-endian** integers. The XML below
      models them as 2 bytes each with separate trailing `Unknown` 2-byte fields; in
      practice those four bytes are a single u32 in each case.
    - `ItemCategory` (in ShipSlot) is a **power-of-two category bitmask**; `0x0000` = empty slot.
  See ../docs/designs.md (type 26) for the corrected layout.
-->
<Structure26 Description="Ship/Starbase Design Data">
  <Unknown bytes="2">
    <Unknown bits="2"/>
    <FullDesign bits="1"/>
    <Unknown bits="7"/>
    <DesignID bits="5"/>
    <Unknown bits="1"/>
  </Unknown>
  <ShipHullID bytes="1"/>
  <Unknown bytes="1"/>
  <Mass bytes="(1-[Unknown/FullDesign])*2" Description="Only on unknown designs"/>
  <Armour bytes="[Unknown/FullDesign]*2"/>
  <SlotCount bytes="[Unknown/FullDesign]"/>
  <Unknown bytes="[Unknown/FullDesign]*2"/>
  <TotalBuilt bytes="[Unknown/FullDesign]*2"/>
  <Unknown bytes="[Unknown/FullDesign]*2"/>
  <TotalRemaining bytes="[Unknown/FullDesign]*2"/>
  <Unknown bytes="[Unknown/FullDesign]*2"/>
  <ShipSlot bytes="[Unknown/FullDesign]*4" repeat="[SlotCount]">
    <ItemCategory bits="16"/>
    <ItemID bits="8"/>
    <ItemCount bits="8"/>
  </ShipSlot>
  <NameLength bytes="1"/>
  <Name bytes="[NameLength]" type="StarsText"/>
</Structure26>